PORT=3000

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=your_database
RESULTS_DATABASE=DI

# Table to read data from
MYSQL_TABLE=your_table
# Primary key column for single-record fetch
MYSQL_PRIMARY_KEY=id

# Optional
MYSQL_POOL_LIMIT=10

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

# Comma-separated list of emails allowed to edit/submit action points.
# Use * to allow all authenticated users.
ACTION_POINT_EDITOR_EMAILS=*
